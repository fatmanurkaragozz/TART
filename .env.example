# --- TART PROJECT - ÖRNEK ÇEVRE DEĞİŞKENLERİ (.env.example) ---
# Bu dosyayı ".env" olarak kopyalayın ve kendi gerçek değerlerinizle doldurun.
# GERÇEK ŞİFRELERİ VEYA ANAHTARLARI ASLA GİT'E PUSH ETMEYİN!

# --- VERİTABANI (Supabase / PostgreSQL) ---
# Prisma bağlantı adresleri. Havuzlama (pooling) için port 6543, doğrudan bağlantı için port 5432 kullanılır.
DATABASE_URL="postgresql://kullanici_adi:sifre@host_adresi:6543/veritabani_adi?pgbouncer=true"
DIRECT_URL="postgresql://kullanici_adi:sifre@host_adresi:5432/veritabani_adi"

# --- SUNUCU AYARLARI ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- AUTH (JWT) ---
# JWT token imzalama için kullanılacak rastgele güçlü bir gizli anahtar
JWT_SECRET=ornek_cok_guclu_bir_gizli_anahtar_buraya_gelecek
JWT_EXPIRE=30d

# --- E-POSTA AYARLARI (Nodemailer) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=tart.platform_ornek@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=tart.platform_ornek@gmail.com
FRONTEND_URL=http://localhost:5173

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String       @id @default(uuid()) @db.Uuid
  username    String       @unique
  fullName    String?      // Ad Soyad alanı eklendi
  email       String       @unique
  password    String
  role                String       @default("user")
  resetPasswordToken  String?      @map("reset_password_token")
  resetPasswordExpire DateTime?    @map("reset_password_expire")
  createdAt           DateTime     @default(now()) @map("created_at")
  discussions         Discussion[]
  comments            Comment[]
  votes               Vote[]
  notifications       Notification[]
  recommendations     Recommendation[]
  
  // Takip Sistemi (Kendi kendine ilişki)
  followedBy User[] @relation("UserFollows")
  following  User[] @relation("UserFollows")

  @@map("users")
}


model Discussion {
  id        String    @id @default(uuid()) @db.Uuid
  title     String
  content   String    @db.Text
  authorId  String    @map("author_id") @db.Uuid
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags      Json      @default("[]")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  comments  Comment[]
  votes     Vote[]
  recommendations Recommendation[]

  @@map("discussions")
  @@index([authorId])
}

model Comment {
  id           String     @id @default(uuid()) @db.Uuid
  content      String     @db.Text
  authorId     String     @map("author_id") @db.Uuid
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  discussionId String     @map("discussion_id") @db.Uuid
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parentId     String?    @map("parent_id") @db.Uuid
  parent       Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]  @relation("CommentReplies")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  votes        Vote[]

  @@map("comments")
  @@index([discussionId])
  @@index([parentId])
  @@index([authorId])
}

model Vote {
  id           String      @id @default(uuid()) @db.Uuid
  value        Int         // 1 for upvote, -1 for downvote
  userId       String      @map("user_id") @db.Uuid
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionId String?     @map("discussion_id") @db.Uuid
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  commentId    String?     @map("comment_id") @db.Uuid
  comment      Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@unique([userId, commentId])
  @@index([discussionId])
  @@index([commentId])
  @@map("votes")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderId  String?  @map("sender_id") @db.Uuid
  type      String   // COMMENT, VOTE, SYSTEM
  message   String
  targetId  String?  @map("target_id") // ID of discussion or comment
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model ContactMessage {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Recommendation {
  id           String      @id @default(uuid()) @db.Uuid
  title        String
  type         String
  label        String
  coverUrl     String?     @map("cover_url")
  description  String      @db.Text
  isAi         Boolean     @default(false) @map("is_ai")
  authorId     String?     @map("author_id") @db.Uuid
  author       User?       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  discussionId String?     @map("discussion_id") @db.Uuid
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now()) @map("created_at")

  @@map("recommendations")
  @@index([discussionId])
  @@index([authorId])
}
